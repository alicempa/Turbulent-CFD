FoamFile
{
    version     2.0;
    format      ascii;
    arch        "LSB;label=32;scalar=64";
    class       volVectorField;
    location    "100";
    object      wallShearStress;
}
// * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * //

dimensions      [0 2 -2 0 0 0 0];

internalField   uniform (0 0 0);

boundaryField
{
    top_wall
    {
        type            calculated;
        value           uniform (-0.0948026 4.41738e-21 0);
    }
    inlet
    {
        type            cyclic;
    }
    bot_wall
    {
        type            calculated;
        value           uniform (-0.0948026 8.63564e-18 0);
    }
    outlet
    {
        type            cyclic;
    }
    frontAndBack
    {
        type            empty;
    }
}


